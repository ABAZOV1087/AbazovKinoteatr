<Page x:Class="AbazovKinoteatr.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AbazovKinoteatr"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Личный кабинет">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Личный кабинет" FontSize="26" FontWeight="Bold"/>
            <TextBlock x:Name="UserNameTxt" FontSize="18" Margin="0,10,0,0"/>
            <TextBlock x:Name="UserLoginTxt" FontSize="14" Foreground="Gray"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Ваши билеты:" FontSize="20" FontWeight="Bold" Margin="0,10"/>

        <ListView x:Name="TicketsList" Grid.Row="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Фильм" DisplayMemberBinding="{Binding Sessions.Movies.Title}" Width="200"/>
                    <GridViewColumn Header="Зал" DisplayMemberBinding="{Binding Sessions.Halls.HallName}"/>
                    <GridViewColumn Header="Дата сеанса" DisplayMemberBinding="{Binding Sessions.SessionDateTime, StringFormat='{}{0:dd.MM HH:mm}'}"/>
                    <GridViewColumn Header="Место" DisplayMemberBinding="{Binding Seats.SeatNumber}"/>
                    <GridViewColumn Header="Дата покупки" DisplayMemberBinding="{Binding PurchaseDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Content="На главную" VerticalAlignment="Top" HorizontalAlignment="Right" Click="BackClick" Width="100"/>
    </Grid>
</Page>