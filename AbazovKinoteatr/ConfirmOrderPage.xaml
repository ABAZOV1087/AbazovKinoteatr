<Page x:Class="AbazovKinoteatr.Pages.ConfirmOrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AbazovKinoteatr"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Оформление билета">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Оформление билета" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock x:Name="MovieTxt" FontSize="18" Margin="0,5"/>
        <TextBlock x:Name="HallTxt" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="DateTimeTxt" FontSize="16" Margin="0,5"/>
        <TextBlock x:Name="SeatTxt" FontSize="16" Margin="0,5" Foreground="Green" FontWeight="Bold"/>
        <TextBlock x:Name="PriceTxt" FontSize="20" Margin="0,20" FontWeight="Bold"/>

        <Button Content="Подтвердить" Width="200" Height="45" Click="ConfirmClick" Background="LightGreen"/>
        <Button Content="Отмена" Width="100" Margin="0,10,0,0" Click="CancelClick"/>
    </StackPanel>
</Page>
