<Page x:Class="AbazovKinoteatr.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AbazovKinoteatr"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
Title="Кинотеатр">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="LoginBtn" Content="Вход" Click="LoginClick" Margin="5" Width="80"/>
            <Button x:Name="RegBtn" Content="Регистрация" Click="RegClick" Margin="5" Width="100"/>
            <Button x:Name="ProfileBtn" Content="Личный кабинет" Click="ProfileClick" Margin="5" Visibility="Collapsed"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBox x:Name="SearchBox" Width="200" TextChanged="UpdateList"/>
            <ComboBox x:Name="SortCombo" Width="150" Margin="10,0" SelectionChanged="UpdateList">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="По названию"/>
                <ComboBoxItem Content="По рейтингу"/>
            </ComboBox>
        </StackPanel>

        <ListView x:Name="MoviesList" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="MovieSelect">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemWidth="220"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5" Width="200">
                        <StackPanel>
                            <Image Source="{Binding Poster}" Height="250" Width="180" Stretch="UniformToFill"/>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,5"/>
                            <TextBlock Text="{Binding Rating, StringFormat='Рейтинг: {0}'}"/>
                            <TextBlock Text="{Binding ReleaseDate, StringFormat='Начало: {0:dd.MM.yyyy}'}"/>
                            <TextBlock Text="{Binding AgeRating}" Foreground="Red" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
