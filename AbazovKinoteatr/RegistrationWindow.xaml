<Window x:Class="AbazovKinoteatr.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbazovKinoteatr"
        mc:Ignorable="d"
        Title="Регистрация" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="ФИО"/>
        <TextBox x:Name="NameBox"/>
        <TextBlock Text="Логин" Margin="0,10,0,0"/>
        <TextBox x:Name="LoginBox"/>
        <TextBlock Text="Пароль" Margin="0,10,0,0"/>
        <PasswordBox x:Name="PassBox"/>
        <Button Content="Зарегистрироваться" Margin="0,20" Click="RegisterClick"/>
        <Button Content="Назад" Click="BackClick"/>
    </StackPanel>
</Window>
